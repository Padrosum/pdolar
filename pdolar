#!/bin/bash

# Renk Tanımlamaları (Nord/Minimalist Tema)
BLUE='\033[0;34m'
CYAN='\033[0;36m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
RESET='\033[0m'
BOLD='\033[1m'

# Argüman Kontrolü
if [ -z "$1" ]; then
    echo -e "${RED}❌ Hata: Bir miktar girmelisiniz.${RESET}"
    echo -e "${CYAN}Kullanım: pdolar <miktar>${RESET}"
    exit 1
fi

AMOUNT=$1
URL="https://wise.com/tr/currency-converter/usd-to-try-rate?amount=$AMOUNT"
USER_AGENT="Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36"

echo -e "\n${BLUE}⏳ Veriler çekiliyor...${RESET}"

# Veriyi çek ve HTML içinden ilgili value değerini ayıkla
# grep -Po ile 'value="' kısmından sonrasını yakalıyoruz
RESULT=$(curl -s -A "$USER_AGENT" "$URL" | \
         grep -oP 'id="target-input"[^>]*value="\K[^"]+')

if [ -z "$RESULT" ]; then
    echo -e "${RED}❌ Değer alınamadı. Site yapısı değişmiş veya internet bağlantısı yok.${RESET}"
    exit 1
fi

# Arayüz Çıktısı
echo -e "${CYAN}┌──────────────────────────────────────────┐${RESET}"
echo -e "${CYAN}│${RESET}  ${BOLD}${YELLOW}DÖVİZ KURU (Wise)${RESET}                     ${CYAN}│${RESET}"
echo -e "${CYAN}├──────────────────────────────────────────┤${RESET}"
echo -e "${CYAN}│${RESET}  ${GREEN}$AMOUNT USD${RESET}  ${BOLD}==>${RESET}  ${YELLOW}$RESULT TRY${RESET}          ${CYAN}│${RESET}"
echo -e "${CYAN}└──────────────────────────────────────────┘${RESET}\n"
